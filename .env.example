# =============================================================
# .env.example — Buscador C&D | Cia de Talentos
# =============================================================
# Copie este arquivo como .env e preencha os valores reais.
# NUNCA versione o .env no Git. Adicione .env ao .gitignore.
# =============================================================

# -------------------------------------------------------------
# SUPABASE
# -------------------------------------------------------------
# URL do seu projeto Supabase (encontrado em Project Settings > API)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Service role key — use APENAS no backend/scripts de importação
# NUNCA exponha no frontend ou cliente
SUPABASE_SERVICE_KEY=eyJ...

# Anon key — pode ser usada no frontend (acesso limitado pelas RLS policies)
SUPABASE_ANON_KEY=eyJ...

# String de conexão direta ao Postgres (para migrações, ORMs etc.)
DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# -------------------------------------------------------------
# MICROSOFT GRAPH / ENTRA ID
# -------------------------------------------------------------
# Obtidos no Azure Portal > App Registrations > Seu App
SP_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLIENT_SECRET=sua_client_secret_aqui

# Scope para client credentials (não alterar para o MVP)
GRAPH_SCOPE=https://graph.microsoft.com/.default

# -------------------------------------------------------------
# APLICAÇÃO
# -------------------------------------------------------------
# URL base do backend (usada nos links de resposta enviados por e-mail)
APP_BASE_URL=https://seu-backend.exemplo.com

# Ambiente: development | production
NODE_ENV=development

# Porta do servidor backend
PORT=3000

# -------------------------------------------------------------
# NOTIFICAÇÕES
# -------------------------------------------------------------
# Canal padrão para acionamento: 'email' ou 'teams'
NOTIFICATION_CHANNEL=email

# Remetente dos e-mails de acionamento (deve ser uma conta válida no tenant)
# O Graph enviará e-mails em nome deste endereço (requer Mail.Send)
EMAIL_FROM=buscador-cd@ciadetalentos.com

# (Opcional) Webhook do Teams para notificações simples sem Adaptive Cards
# Deixe vazio se usar e-mail no MVP
TEAMS_WEBHOOK_URL=

# -------------------------------------------------------------
# SEGURANÇA
# -------------------------------------------------------------
# Secret para assinar/verificar tokens de resposta das consultoras
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RESPONSE_TOKEN_SECRET=gere_um_valor_aleatorio_aqui_64_chars_hex

# Expiração dos tokens de resposta (em horas)
RESPONSE_TOKEN_TTL_HOURS=48

# -------------------------------------------------------------
# IMPORTAÇÃO EXCEL (somente para o script import_excel.py)
# -------------------------------------------------------------
EXCEL_PATH=./C&D - Cadastro de Consultoras 2026-27.xlsx
